# ============================================================
# OmegaBot — Environment Configuration
# Copy to .env and fill in your actual credentials
# NEVER commit .env to git
# ============================================================

APP_NAME=OmegaBot
APP_ENV=production
SECRET_KEY=change-me-to-random-32-char-string
DEBUG=false

# ─── PostgreSQL (Aiven) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://avnadmin:YOUR_PASSWORD@your-host.aivencloud.com:PORT/defaultdb?ssl=require

# ─── Redis (RedisCloud) ───────────────────────────────────────────────────────
REDIS_URL=redis://default:YOUR_PASSWORD@your-redis-host.redislabs.com:PORT
CELERY_BROKER_URL=redis://default:YOUR_PASSWORD@your-redis-host.redislabs.com:PORT/1
CELERY_RESULT_BACKEND=redis://default:YOUR_PASSWORD@your-redis-host.redislabs.com:PORT/2

# ─── InfluxDB (optional — OHLCV time-series) ─────────────────────────────────
INFLUXDB_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=omegabot_ohlcv

# ─── MongoDB (optional — Journal/Strategy store) ─────────────────────────────
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_DB=omegabot

# ─── Binance (for real crypto prices) ────────────────────────────────────────
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BINANCE_TESTNET=false

# ─── Groww (Indian equities) ─────────────────────────────────────────────────
GROWW_ACCESS_TOKEN=your-groww-jwt-token
GROWW_API_SECRET=your-groww-secret
GROWW_BASE_URL=https://api.groww.in/v1

# ─── AI Providers ────────────────────────────────────────────────────────────
# Primary: Google Gemini (free tier available)
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# Secondary: NVIDIA NIM
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── Trading ─────────────────────────────────────────────────────────────────
DEFAULT_TRADING_MODE=paper
DEFAULT_BROKER=mock

# ─── Risk ─────────────────────────────────────────────────────────────────────
DEFAULT_MAX_DAILY_LOSS=5000
DEFAULT_MAX_TRADE_LOSS=1000
DEFAULT_MAX_POSITIONS=10
DEFAULT_MAX_ORDER_VALUE=50000

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:13000","http://127.0.0.1:13000"]

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:18000
NEXT_PUBLIC_WS_URL=ws://localhost:18000
