# ============================================================
# OmegaBot — Environment Configuration
# Copy to .env and edit. Defaults work locally out of the box.
# ============================================================

APP_NAME=OmegaBot
APP_ENV=development
SECRET_KEY=change-me-in-production-32chars-minimum
DEBUG=true

# ─── PostgreSQL (local Docker) ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=omegabot
POSTGRES_USER=omegabot
POSTGRES_PASSWORD=omegabot_secret
DATABASE_URL=postgresql+asyncpg://omegabot:omegabot_secret@postgres:5432/omegabot

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@redis:6379/0
REDIS_PASSWORD=redis_secret
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/2

# ─── AI Providers (optional) ──────────────────────────────────────────────────
AI_PROVIDER=openai
DEFAULT_AI_PROVIDER=openai
ENABLE_AI_FALLBACK=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=

# ─── Broker Credentials (optional) ───────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
GROWW_ACCESS_TOKEN=
GROWW_API_SECRET=
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# ─── Storage (optional) ───────────────────────────────────────────────────────
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=omegabot_ohlcv
MONGO_URL=
MONGO_DB=omegabot

# ─── Notifications (optional) ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TRADINGVIEW_WEBHOOK_SECRET=

# ─── Trading Defaults ─────────────────────────────────────────────────────────
DEFAULT_TRADING_MODE=paper
DEFAULT_BROKER=mock
DEFAULT_MAX_DAILY_LOSS=5000
DEFAULT_MAX_TRADE_LOSS=1000
DEFAULT_MAX_POSITIONS=10
DEFAULT_MAX_ORDER_VALUE=50000

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:13000","http://127.0.0.1:13000"]

# ─── Frontend (used by Next.js build) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:18000
NEXT_PUBLIC_WS_URL=ws://localhost:18000

# Local ports (docker-compose.local.yml)
WEB_PORT=13000
LOCAL_API_URL=http://localhost:18000
LOCAL_WS_URL=ws://localhost:18000
